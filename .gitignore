# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
/vinculum

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# local RabbitMQ integration-test credentials (never commit)
rabbitmq.env

# Notes
FUTURE
TODO.md
*-SPEC.md
*-MVP.md

# Test/scratch files
test*.vcl
*-smoke-test.vcl
smoke*.vcl
x

# Claude Code workflow scratch (todo.md, lessons.md)
tasks/

# Local MCP config
.mcp.json

# Editor/IDE
.idea/
.vscode/

# spec documents
specs/
